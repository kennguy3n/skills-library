    {
      "name": "Private Key Block",
      "regex": "-----BEGIN (RSA |EC |DSA |OPENSSH |PGP )?PRIVATE KEY-----",
      "prefix": "-----BEGIN",
      "severity": "critical",
      "score_weight": 2,
      "hotwords": [],
      "hotword_window": 0,
      "hotword_boost": 0,
      "require_hotword": false,
      "entropy_min": 0
    },
    {
      "name": "JWT Token",
      "regex": "eyJ[A-Za-z0-9_\\-]+\\.eyJ[A-Za-z0-9_\\-]+\\.[A-Za-z0-9_\\-]+",
      "prefix": "eyJ",
      "severity": "medium",
      "score_weight": 1,
      "hotwords": ["jwt", "bearer", "auth", "token"],
      "hotword_window": 200,
      "hotword_boost": 2,
      "require_hotword": false,
      "entropy_min": 3.5
    },
    {
      "name": "Generic High-Entropy Secret",
      "regex": "(?i)(secret|password|passwd|pwd)\\s*[:=]\\s*['\"][^'\"\\s]{16,}['\"]",
      "prefix": "secret",
      "severity": "high",
      "score_weight": 1,
      "hotwords": ["secret", "password", "credential"],
      "hotword_window": 50,
      "hotword_boost": 1,
      "require_hotword": true,
      "entropy_min": 3.5
    }
  ]
}
